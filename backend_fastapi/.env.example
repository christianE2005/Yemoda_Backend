# ─────────────────────────────────────────────────────────────────────────────
# FastAPI backend — environment variables
# Copy to .env and fill in. Several values MUST match the Django service (noted below).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Takes precedence over DATABASE_URL if both are set. MUST point to the SAME
# Postgres as the Django service (shared tables: usage, members, projects…).
FASTAPI_DATABASE_URL=postgresql+psycopg2://user:password@your-db-host:5432/your-db-name
# DATABASE_URL is used as a fallback if FASTAPI_DATABASE_URL is unset.
# DATABASE_URL=postgresql+psycopg2://user:password@your-db-host:5432/your-db-name

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...   # (REQUIRED — used for code review + chat)
# Every AI surface (push reviews, hackathon audit + verify, chat, ai-fix) runs on
# claude-haiku-4-5 by default. Override per surface only if you accept the extra cost:
# HACKATHON_AI_MODEL=claude-haiku-4-5
# HACKATHON_VERIFY_MODEL=claude-haiku-4-5

# ── Internal service-to-service auth ─────────────────────────────────────────
# REQUIRED. Shared secret expected in the X-Internal-Token header on /chat/*, /predictions/*,
# /audit/* and /webhook/review-task|drain-pending. MUST match Django's FASTAPI_INTERNAL_TOKEN.
# Without it, all internal endpoints reject every call (fail-closed 401).
FASTAPI_INTERNAL_TOKEN=replace-with-a-random-internal-token

# ── GitHub App credentials (same values as the Django backend) ───────────────
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Webhook secret — validates the HMAC-SHA256 signature of GitHub push webhooks; must be the
# same value as in Django. (The Django↔FastAPI internal auth is FASTAPI_INTERNAL_TOKEN above.)
GITHUB_APP_WEBHOOK_SECRET=replace-with-your-webhook-secret

# ── AI metering / quotas ─────────────────────────────────────────────────────
# These MUST match the Django service exactly: Django reports usage, FastAPI enforces it.
AI_METERING_ENFORCE=true
# Pro plan: per-seat allowance, pooled across project members.
AI_QUOTA_REVIEWS_PER_SEAT=50
AI_QUOTA_CHAT_PER_SEAT=50
AI_QUOTA_AIFIX_PER_SEAT=10
# Free plan: flat cap per project (NOT multiplied by seats).
AI_FREE_QUOTA_REVIEWS=10
AI_FREE_QUOTA_CHAT=10
AI_FREE_QUOTA_AIFIX=1

# ── AI price overrides (optional) ────────────────────────────────────────────
# Only set to override the built-in pricing used for cost logging (USD per 1M tokens).
# AI_PRICE_CLAUDE_HAIKU_4_5_INPUT=1.0
# AI_PRICE_CLAUDE_HAIKU_4_5_OUTPUT=5.0
# AI_PRICE_CLAUDE_SONNET_4_6_INPUT=3.0
# AI_PRICE_CLAUDE_SONNET_4_6_OUTPUT=15.0
# AI_PRICE_CLAUDE_OPUS_4_6_INPUT=5.0
# AI_PRICE_CLAUDE_OPUS_4_6_OUTPUT=25.0
