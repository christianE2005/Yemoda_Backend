DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173

DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password

JWT_SECRET_KEY=replace-with-a-secure-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=10080

GITHUB_APP_ID=123456
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_APP_CLIENT_ID=Iv23li...
GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret
GITHUB_APP_OAUTH_CALLBACK_URL=http://127.0.0.1:8001/api/github/app/oauth/callback/
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=replace-with-a-webhook-secret
GITHUB_APP_WEBHOOK_TARGET_URL=https://your-public-domain.com/api/github/webhook/push/
