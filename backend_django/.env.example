# ─────────────────────────────────────────────────────────────────────────────
# Django backend — environment variables
# Copy to .env and fill in. Vars marked (REQUIRED) have no safe default.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core / Django ────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-secure-secret-key   # (REQUIRED)
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
# RAILWAY_ENVIRONMENT is set automatically by Railway; only set manually if needed.
# RAILWAY_ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────────
# Option A — single DATABASE_URL (Railway/Aiven style, takes priority if set).
# NOTE: must point to the SAME Postgres as the FastAPI service.
DATABASE_URL=postgresql://user:password@your-db-host:5432/your-db-name?sslmode=require
# Option B — individual vars (used as fallback when DATABASE_URL is not set)
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-secure-jwt-secret   # falls back to DJANGO_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=10080

# Refresh-token HttpOnly cookie. Defaults fit a same-site subdomain deploy
# (e.g. frontend yemoda.site + backend api.yemoda.site → SameSite=Lax).
# If the frontend is on a different registrable domain (e.g. *.vercel.app),
# set REFRESH_COOKIE_SAMESITE=None (and keep REFRESH_COOKIE_SECURE=true).
REFRESH_COOKIE_NAME=yemoda_refresh
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_DOMAIN=          # e.g. .yemoda.site to share across subdomains; empty = host-only
REFRESH_COOKIE_PATH=/api/auth/

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yemoda.site
CORS_ALLOW_ALL_ORIGINS=false

# ── Cross-service URL ────────────────────────────────────────────────────────
# Base URL of the FastAPI service; Django calls it (e.g. to drain queued AI reviews).
FASTAPI_CHAT_BASE_URL=https://fast.yemoda.site

# ── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=123456                                  # (REQUIRED)
GITHUB_APP_SLUG=your-github-app-slug                  # (REQUIRED)
GITHUB_APP_CLIENT_ID=Iv23li...                        # (REQUIRED)
GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret # (REQUIRED)
GITHUB_APP_OAUTH_CALLBACK_URL=https://api.yemoda.site/api/github/app/oauth/callback/  # (REQUIRED)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"  # (REQUIRED)
# Webhook secret — also reused as the internal X-Internal-Token between Django and FastAPI,
# so it MUST be identical in both services. (REQUIRED)
GITHUB_APP_WEBHOOK_SECRET=replace-with-a-webhook-secret
GITHUB_APP_WEBHOOK_TARGET_URL=https://api.yemoda.site/api/github/webhook/push/  # (REQUIRED)
GITHUB_APP_STATE_SECRET=replace-with-a-random-state-secret   # falls back to JWT_SECRET_KEY
# Frontend URL to land on after the GitHub auth flow completes
GITHUB_AUTH_FRONTEND_REDIRECT=https://yemoda.site/auth/github/callback

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=123456789-abcdef.apps.googleusercontent.com   # (REQUIRED)
GOOGLE_CLIENT_SECRET=GOCSPX-...                                 # (REQUIRED)
GOOGLE_REDIRECT_URI=https://api.yemoda.site/api/google/callback/  # (REQUIRED)
GOOGLE_AUTH_FRONTEND_REDIRECT=https://yemoda.site/auth/google/callback
GOOGLE_STATE_SECRET=replace-with-a-random-state-secret   # falls back to JWT_SECRET_KEY

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                                  # (REQUIRED to send emails)
RESEND_FROM_EMAIL=noreply@yemoda.site
EMAIL_VERIFICATION_BASE_URL=https://yemoda.site/auth/verify-email
EMAIL_VERIFIED_REDIRECT=https://yemoda.site/auth/verified
# Unverified-account grace window (days) before the API blocks the account
EMAIL_VERIFICATION_GRACE_DAYS=3

# ── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...        # (REQUIRED for billing)
STRIPE_WEBHOOK_SECRET=whsec_...      # (REQUIRED for billing)
# IMPORTANT: these must be PER-SEAT (per-unit) recurring prices — quantity = members.
STRIPE_PRICE_ID_MONTHLY=price_...    # (REQUIRED for billing)
STRIPE_PRICE_ID_ANNUAL=price_...     # (REQUIRED for billing)
STRIPE_SUCCESS_URL=https://yemoda.site/payment/success
STRIPE_CANCEL_URL=https://yemoda.site/payment/cancel

# ── AI metering / quotas ─────────────────────────────────────────────────────
# These MUST match the FastAPI service exactly: Django reports usage, FastAPI enforces it.
AI_METERING_ENFORCE=true
# Pro plan: per-seat allowance, pooled across project members.
AI_QUOTA_REVIEWS_PER_SEAT=50
AI_QUOTA_CHAT_PER_SEAT=50
AI_QUOTA_AIFIX_PER_SEAT=10
# Free plan: flat cap per project (NOT multiplied by seats).
AI_FREE_QUOTA_REVIEWS=10
AI_FREE_QUOTA_CHAT=10
AI_FREE_QUOTA_AIFIX=1
